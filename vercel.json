{
  "version": 2,
  "buildCommand": "npm install && cd frontend && npm install && npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/index.js": {
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ]
}